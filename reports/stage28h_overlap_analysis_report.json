  "key_findings": [
    "product_p0p90 has the lowest false SUPPORT count (44 total) across all three configurations and is the most stable decision signal.",
    "learned-only has severe instability across seeds, especially seed1 (90 false SUPPORT vs. 31 for product), and rescues zero product location false SUPPORT errors.",
    "hybrid_beta0p20 provides only local rescue (6 total rescues) at the cost of a substantially worse aggregate tradeoff (39 introductions), and degrades seed2 and seed3.",
    "missing_evidence false SUPPORT is zero for all configurations and all seeds; sufficiency/missing-evidence rejection is already solved.",
    "location is the dominant unresolved product false SUPPORT axis: 27 of 44 product false SUPPORT errors (61.4%) are location-axis errors.",
    "learned/hybrid residuals should not be used as the location specialist mechanism; neither signal reliably corrects location false SUPPORT errors and both introduce many new ones."
  ],
  "rejected_mechanisms": [
    {
      "mechanism": "learned-only decision signal",
      "reason": "136 total false SUPPORT errors (3.1x product), zero location rescues, 94 new introductions, severe seed instability"
    },
    {
      "mechanism": "product_learned_residual hybrid (beta=0.20)",
      "reason": "77 total false SUPPORT errors (1.75x product), only 6 rescues against 39 introductions, degrades seed2 and seed3, 19 new location errors against 3 rescues"
    }
  ],
  "retained_baseline": {
    "signal": "product_p0p90",
    "decision_signal": "product",
    "product_power": 0.9,
    "false_support_total": 44,
    "location_false_support": 27,
    "status": "frozen Stage27/Stage28 baseline"
  },
  "design_consequence": "The only reliable path to reducing product location false SUPPORT errors is an independent bounded location-boundary specialist that operates on location-axis examples only, applies a hard or soft cap rather than learned signal mixing, and does not modify the product signal for non-location axes. Learned/hybrid residual approaches are excluded by the overlap evidence.",
  "decision": [
    "Retain product_p0p90 as the frozen Stage27/Stage28 baseline: lowest aggregate false SUPPORT count (44) and lowest location false SUPPORT count (27).",
    "Reject learned-only as a final decision signal: 136 total false SUPPORT, zero location rescues, 94 introductions, severe seed instability.",
    "Reject product_learned_residual hybrid as a specialist mechanism: 77 total false SUPPORT, 6 rescues vs. 39 introductions, degrades seed2 and seed3.",
    "Preserve missing-evidence/sufficiency behavior: zero missing_false_SUPPORT across all configs and seeds; must not be disturbed by any future stage.",
    "Move next to Stage28-I independent location-boundary cap/head design or implementation planning.",
    "Stage28-H is analysis and reporting only: no model improvement claimed from this stage.",
    "No OOD generalization claimed."
  ],
  "next_stage_recommendation": {
    "stage": "Stage28-I",
    "title": "Independent Bounded Location-Boundary Cap/Head",
    "requirements": [
      "Design a location-boundary specialist that is architecturally independent from the product score computation",
      "Bound the specialist correction magnitude to prevent signal collapse",
      "Target the 27 product location false SUPPORT errors across seeds 1-3 as the reduction objective",
      "Evaluate on controlled_v5_v3_without_time_swap.jsonl (controlled no-time validation)",
      "Maintain frozen encoder, freeze_a_log, max_length=64 constraints",
      "Leave the sufficiency/missing-evidence rejection path unchanged",
      "Do not use learned signal components or hybrid mixing as part of the specialist mechanism"
    ],
    "scope": "Design and planning only, consistent with the analysis-only scope established in Stage28-H"
  },
  "limitations": [
    "Controlled no-time validation only: results are on controlled_v5_v3_without_time_swap.jsonl; no OOD claim can be made.",
    "max_length=64: all results are under this truncation limit; behavior at longer sequence lengths is not measured.",
    "Frozen encoder: the encoder is frozen throughout Stage28; fine-grained location discrimination may require encoder fine-tuning not tested here.",
    "No OOD claim: behavior on unseen validation distributions is unknown.",
    "No full-encoder claim: full encoder fine-tuning results are not available in this stage.",
    "Stage28-H is analysis-only: no model code, training code, or scripts are modified or executed.",
    "Location cap/head not implemented yet: Stage28-H establishes the requirement only; Stage28-I will carry the design.",
    "Examples are synthetic controlled examples: real-world distribution behavior is not measured.",
    "Stage28-C-lite manually inspected 20 location examples only: the full distribution of location false SUPPORT error types is not characterized.",
    "300 location_swap examples are not guaranteed to be fully clean: manual audit covered 20 examples; the remainder have not been individually inspected.",
    "Seed instability is a persistent concern: product_p0p90 itself shows high variance across seeds (false_SUPPORT: 31, 12, 1)."
  ],
  "conclusion": "Stage28-G rejects learned and hybrid residuals as reliable correction mechanisms: they rescue too few product false SUPPORT errors while introducing substantially more new false SUPPORT errors. The next specialist should use an independent bounded location-boundary cap, not learned/hybrid residual mixing."
}
