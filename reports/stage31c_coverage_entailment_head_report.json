{
  "stage": "Stage31-C2",
  "artifact": "coverage_entailment_diagnostic_head",
  "purpose": "Readout-only directional Coverage/Entailment diagnostic owner.",
  "auxiliary_data": {
    "path": "data/stage31c_coverage_entailment_aux.jsonl",
    "separate_from_stage31_eval_probe": true,
    "default_num_classes": 3,
    "coverage_direction_mapping": {
      "ENTAILS_SUPPORT": 0,
      "OVERCLAIM_NOT_ENTITLED": 1,
      "CONTRADICTS_REFUTE": 2
    },
    "direction_to_final_label": {
      "ENTAILS_SUPPORT": "SUPPORT",
      "OVERCLAIM_NOT_ENTITLED": "NOT_ENTITLED",
      "CONTRADICTS_REFUTE": "REFUTE"
    },
    "final_label_mapping": {
      "REFUTE": 0,
      "NOT_ENTITLED": 1,
      "SUPPORT": 2
    },
    "expected_counts": {
      "total_rows": 900,
      "train": 720,
      "dev": 180,
      "per_class": {
        "ENTAILS_SUPPORT": 300,
        "OVERCLAIM_NOT_ENTITLED": 300,
        "CONTRADICTS_REFUTE": 300
      }
    },
    "contains_other_residual_by_default": false
  },
  "head_architecture": {
    "input": "concat([frame_pair_repr, predicate_pair_repr, sufficiency_repr])",
    "output_classes_arg": "--v7-coverage-entailment-num-classes",
    "default_output_classes": 3,
    "legacy_output_classes": 4,
    "loss": "optional cross entropy over coverage_direction_id"
  },
  "exported_columns": {
    "default_3_class": [
      "coverage_entails_support_prob",
      "coverage_overclaim_ne_prob",
      "coverage_contradicts_refute_prob",
      "coverage_entailment_pred_id",
      "coverage_entailment_pred_label",
      "coverage_entailment_confidence"
    ],
    "legacy_4_class_additional": [
      "coverage_other_residual_prob"
    ]
  },
  "stage31_probe_alignment": {
    "support_entailment_groups": "ENTAILS_SUPPORT",
    "not_entitled_overclaim_groups": "OVERCLAIM_NOT_ENTITLED",
    "refute_groups": "CONTRADICTS_REFUTE",
    "evaluator_supports_3_class_exports": true,
    "evaluator_supports_4_class_exports": true,
    "safety_counters": [
      "refute_misread_as_entails_support",
      "overclaim_misread_as_entails_support",
      "support_misread_as_overclaim_ne",
      "support_misread_as_contradicts_refute"
    ]
  },
  "diagnostic_only_constraints": {
    "modifies_output_logits": false,
    "modifies_h1_final_composer": false,
    "modifies_entitlement": false,
    "adds_cap": false,
    "adds_ne_boost": false,
    "used_for_checkpoint_selection": false,
    "uses_stage31_eval_probe_for_loss": false,
    "uses_stage31_eval_probe_for_calibration": false,
    "uses_stage31_eval_probe_for_threshold_selection": false
  },
  "leakage_policy": "Do not use data/stage31_coverage_entailment_probe.jsonl for training, calibration, threshold selection, checkpoint selection, or auxiliary loss construction."
}
